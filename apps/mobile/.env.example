# URL da API NestJS.
# Em desenvolvimento (Expo), se você deixar localhost aqui, o app usa automaticamente o mesmo host
# do Metro (IP da LAN no celular físico; no simulador costuma continuar localhost).
# Produção / override explícito: defina a URL completa (ex.: https://api.seudominio.com).
# Simulador iOS: http://localhost:3000 costuma funcionar.
# Emulador Android sem Expo Go: às vezes http://10.0.2.2:3000.
EXPO_PUBLIC_API_URL="http://localhost:3000"
