DATABASE_URL="postgresql://user:password@localhost:5432/oncomente"
JWT_SECRET="change-this-to-a-strong-random-secret"
NODE_ENV="development"

# SMTP — configurar com seu provedor de email (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="OncoMente <seu-email@gmail.com>"
