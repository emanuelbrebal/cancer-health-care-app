DATABASE_URL="postgresql://postgres:postgres@localhost:5432/oncomente"
JWT_SECRET="change-this-to-a-strong-random-secret"
NODE_ENV="development"
PORT="3000"

# Mascote (Groq — OpenAI-compatible API). Obtenha em https://console.groq.com/keys
GROQ_API_KEY=""

# SMTP — configurar com seu provedor de email (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="OncoMente <seu-email@gmail.com>"
