// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// ENUMS GLOBAIS
// ==============================
enum StatusEnum {
  ACTIVE
  INACTIVE
  DELETED
  PENDING
  ARCHIVED
}

// ==============================
// MODELOS: USUÁRIO E ÁREA PESSOAL
// ==============================

enum UserRole {
  PATIENT
  CAREGIVER
  ADMIN
}

enum PronounEnum {
  SR
  SRA
  SRTA
  CUSTOM
  NOT_INFORMED
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique @db.VarChar(200)
  password String
  role     UserRole @default(PATIENT)

  createdAt DateTime @default(now())

  name            String?      @db.VarChar(50)
  pronoun         PronounEnum? @default(NOT_INFORMED)
  phone_number    String?      @db.VarChar(14)
  birthday        DateTime?
  profile_picture String?

  logs DailyLog[]

  ownedCommunities Community[] @relation("CommunityOwner")
  topics           Topic[]     @relation("TopicAuthor")
  posts            Post[]      @relation("PostAuthor")
  comments         Comment[]   @relation("CommentAuthor")
}

model DailyMessage {
  id      String     @id @default(uuid())
  title   String?    @db.VarChar(25)
  message String?    @db.VarChar(25)
  status  StatusEnum @default(ACTIVE)
}

// ==============================
// MODEL: FORUM AND SOCIAL
// ==============================
model Community {
  id          String     @id @default(uuid())
  name        String     @db.VarChar(150)
  description String?    @db.VarChar(500)
  image_path  String?
  status      StatusEnum @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  ownerId String
  owner   User    @relation("CommunityOwner", fields: [ownerId], references: [id])
  topics  Topic[]
}

model Topic {
  id         String     @id @default(uuid())
  title      String     @db.VarChar(150)
  content    String     @db.VarChar(2000)
  image_path String?
  status     StatusEnum @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  authorId String
  author   User   @relation("TopicAuthor", fields: [authorId], references: [id])

  communityId String?
  community   Community? @relation(fields: [communityId], references: [id])
  posts       Post[]
}

model Post {
  id         String     @id @default(uuid())
  content    String
  image_path String?
  status     StatusEnum @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  author   User      @relation("PostAuthor", fields: [authorId], references: [id])
  authorId String
  topic    Topic     @relation(fields: [topicId], references: [id])
  topicId  String
  comments Comment[]
}

model Comment {
  id        String     @id @default(uuid())
  content   String     @db.VarChar(300)
  status    StatusEnum @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  authorId String
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id])
  postId   String
  post     Post   @relation(fields: [postId], references: [id])
}

// ==============================
// MODELS: ONCOLOGY AND MEDIA TYPES
// ==============================

enum GenreType {
  BOOK
  MOVIE
  SERIES
}

model Genre {
  id     String     @id @default(uuid())
  name   String     @unique
  type   MediaType
  status StatusEnum @default(ACTIVE)
  medias Media[]
}

enum MediaType {
  BOOK
  MOVIE
  SERIES
}

model Media {
  id          String     @id @default(uuid())
  title       String     @db.VarChar(150)
  releaseYear Int?
  type        MediaType
  status      StatusEnum @default(ACTIVE)
  isFree      Boolean    @default(false)
  whereToFind String[]   @default([])
  image_path  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  genreId String
  genre   Genre  @relation(fields: [genreId], references: [id])

  bookDetails   BookDetail?
  movieDetails  MovieDetail?
  seriesDetails SeriesDetail?

  @@unique([title, type])
}

enum LeisureType {
  PHYSICAL
  CULTURAL
  SOCIAL
  THERAPY
  RECREATIONAL
  REST
}

enum FrequencyType {
  DAILY
  WEEKLY
  FORTWEEKLY
  MONTHLY
  SPORADICAL
}

model LeisureActivity {
  id         String        @id @default(uuid())
  name       String        @db.VarChar(150)
  type       LeisureType
  frequency  FrequencyType
  image_path String
  status     StatusEnum    @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([name])
}

model SeriesDetail {
  id           String  @id @default(uuid())
  showrunner   String? @db.VarChar(120)
  seasons      Int?
  episodes     Int?
  externalLink String?

  mediaId String @unique
  media   Media  @relation(fields: [mediaId], references: [id])
}

model MovieDetail {
  id           String  @id @default(uuid())
  director     String? @db.VarChar(120)
  duration     String? @db.VarChar(120)
  externalLink String?

  mediaId String @unique
  media   Media  @relation(fields: [mediaId], references: [id])
}

model BookDetail {
  id           String  @id @default(uuid())
  author       String  @db.VarChar(120)
  eduCapesLink String?
  page_count   Int?
  visitCount   Int     @default(0)

  mediaId String @unique
  media   Media  @relation(fields: [mediaId], references: [id])
}

// ==============================
// MODELS: PERSONAL AREA
// ==============================
model DailyLog {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(150)
  content   String   @db.VarChar(2000)
  
  emotes    String[] 
  
  date      DateTime @default(now()) @db.Date 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model DailyLogAudit {
  id        String   @id @default(uuid())
  logId     String
  userId    String
  action    String   
  timestamp DateTime @default(now())
}